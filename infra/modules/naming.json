{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "17898097062661926617"
    }
  },
  "parameters": {
    "workload": {
      "type": "string",
      "metadata": {
        "description": "Short workload name."
      }
    },
    "env": {
      "type": "string",
      "metadata": {
        "description": "Environment short code."
      }
    }
  },
  "variables": {
    "u": "[uniqueString(resourceGroup().id, parameters('workload'), parameters('env'))]",
    "short": "[substring(variables('u'), 0, 6)]",
    "weTagFull": "[toLower(replace(replace(format('{0}{1}', parameters('workload'), parameters('env')), '-', ''), '_', ''))]",
    "weTag": "[if(greater(length(variables('weTagFull')), 14), substring(variables('weTagFull'), 0, 14), variables('weTagFull'))]",
    "weTagSt": "[if(greater(length(variables('weTagFull')), 12), substring(variables('weTagFull'), 0, 12), variables('weTagFull'))]"
  },
  "resources": [],
  "outputs": {
    "names": {
      "type": "object",
      "value": {
        "logAnalytics": "[format('law-{0}-{1}-{2}', parameters('workload'), parameters('env'), variables('short'))]",
        "appInsights": "[format('appi-{0}-{1}-{2}', parameters('workload'), parameters('env'), variables('short'))]",
        "keyVault": "[format('kv-{0}{1}', variables('weTag'), variables('short'))]",
        "appIdentity": "[format('id-{0}-{1}-{2}', parameters('workload'), parameters('env'), variables('short'))]",
        "storage": "[toLower(format('st{0}{1}', variables('weTagSt'), variables('short')))]",
        "search": "[format('srch-{0}-{1}-{2}', parameters('workload'), parameters('env'), variables('short'))]",
        "contentUnderstanding": "[format('cu-{0}-{1}-{2}', parameters('workload'), parameters('env'), variables('short'))]",
        "foundryAccount": "[format('aif-{0}-{1}-{2}', parameters('workload'), parameters('env'), variables('short'))]",
        "foundryProject": "[format('aifp-{0}-{1}-{2}', parameters('workload'), parameters('env'), variables('short'))]",
        "acaEnv": "[format('cae-{0}-{1}-{2}', parameters('workload'), parameters('env'), variables('short'))]",
        "orchestratorApp": "[format('ca-orch-{0}-{1}', variables('weTag'), variables('short'))]",
        "appServicePlan": "[format('asp-{0}-{1}-{2}', parameters('workload'), parameters('env'), variables('short'))]",
        "webApp": "[format('app-web-{0}-{1}-{2}', parameters('workload'), parameters('env'), variables('short'))]",
        "apim": "[format('apim-{0}-{1}-{2}', parameters('workload'), parameters('env'), variables('short'))]"
      }
    }
  }
}