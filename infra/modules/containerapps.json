            "external": true,
            "targetPort": 8080,
            "transport": "auto",
            "allowInsecure": false
          }
        },
        "template": {
          "containers": [
            {
              "name": "orchestrator",
              "image": "mcr.microsoft.com/dotnet/samples:aspnetapp",
              "resources": {
