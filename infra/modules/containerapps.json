                  "value": "[parameters('foundryProjectEndpoint')]"
                },
                {
                  "name": "Azure__ChatModelDeployment",
                  "value": "[parameters('chatModelDeployment')]"
                },
                {
                  "name": "Azure__ImageModelDeployment",
                  "value": "[parameters('imageModelDeployment')]"
                },
                {
                  "name": "Azure__SearchEndpoint",
                  "value": "[parameters('searchEndpoint')]"
                },
                {
                  "name": "Azure__SearchIndexName",
                  "value": "[parameters('searchIndexName')]"
                },
                {
                  "name": "Azure__SearchIndexNames",
                  "value": "[parameters('searchIndexNames')]"
