                },
                {
                  "name": "Azure__BlobAccountUrl",
                  "value": "[parameters('blobAccountUrl')]"
                },
                {
                  "name": "Azure__CatalogContainer",
                  "value": "[parameters('catalogContainer')]"
                },
                {
                  "name": "Azure__GeneratedContainer",
                  "value": "[parameters('generatedContainer')]"
                },
                {
                  "name": "Azure__ContentUnderstandingEndpoint",
                  "value": "[parameters('contentUnderstandingEndpoint')]"
                },
                {
                  "name": "Azure__Agents__ChatAgent",
                  "value": "chat-agent"
